% ------------------------------------------------------------------------------
% Type Uniqueness
% ------------------------------------------------------------------------------

% λ-terms with type annotation
LF tm : type =
  | app : tm → tm → tm
  | lam : tp → (tm → tm) → tm
;

LF hastype: tm -> tp -> type =
  | t/lam : ({x:tm}hastype x T → hastype (M x) S) 
            → hastype (lam T M) (arr T S)
  | t/app : hastype M (arr T S) → hastype N T
            → hastype (app M N) S
;

LF eq: tp -> tp -> type = 
  | ref: eq T T
;

schema tctx = some [t:tp] block (x:tm, u:hastype x t);

% TODO Type uniqueness
% Fill-up the proof for type uniqueness following the companion book. I'll
% spend a bit more time on this proof since it introduces some constructs
% and ideas that we haven't discussed thus far

% THM (Uniqueness): If D ∷ Γ ⊢ M : T and E ∷ Γ ⊢ M : T', then T = T'
rec unique : (Γ:tctx)[Γ ⊢ hastype M T[]] → [Γ ⊢ hastype M T'[]] → [⊢ eq T T'] =
/ total 1 /
fn D ⇒ fn E ⇒ case D of
  | [Γ ⊢ t/app D1 D2] ⇒ ?
  | [Γ ⊢ t/lam \x. \u. D'] ⇒ ?
  | [Γ ⊢ #q.2] ⇒ ? 
;
